{
  "name": "@statewalker/resources-wiki",
  "version": "0.1.0",
  "type": "module",
  "description": "Wiki capabilities for the statewalker resources framework: signal-driven builders and Project/Resource adapters that turn a project's sources into a queryable, layered, LLM-curated wiki.",
  "homepage": "https://github.com/statewalker/statewalker-resources",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-resources.git"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rimraf dist && rolldown -c && tsc --emitDeclarationOnly --declaration -p tsconfig.build.json",
    "start": "tsx bin/wiki.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@statewalker/resources-workspace": "workspace:*",
    "@statewalker/content-extractors": "catalog:",
    "@statewalker/fsm": "catalog:",
    "@statewalker/shared-adapters": "catalog:",
    "@statewalker/indexer-api": "catalog:",
    "@statewalker/indexer-fulltext": "catalog:",
    "@statewalker/indexer-mem-flexsearch": "catalog:",
    "@statewalker/indexer-vector": "catalog:",
    "@statewalker/shared-dataflow": "catalog:",
    "@statewalker/shared-logger": "catalog:",
    "@statewalker/shared-logger-pino": "catalog:",
    "@statewalker/webrun-files": "catalog:",
    "@uwdata/flechette": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "ai": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@statewalker/fsm-validator": "catalog:",
    "@statewalker/webrun-files-mem": "catalog:",
    "@statewalker/webrun-files-node": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "rolldown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
