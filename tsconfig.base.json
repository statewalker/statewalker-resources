{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@statewalker/resources-utils": ["packages/resources-utils/src"],
      "@statewalker/resources-core": ["packages/resources-core/src"],
      "@statewalker/resources-workspace": ["packages/resources-workspace/src"]
    }
  }
}
